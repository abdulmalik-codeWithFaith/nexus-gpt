# Required: OpenAI Responses API key for real Nexus AI answers.
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: override the model used by app/api/ai/* routes.
OPENAI_MODEL=gpt-5.6

# Required: Firebase web app config for cross-device meeting rooms.
# Copy these from Firebase Console → Project settings → General → Your apps → Web app config.
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
