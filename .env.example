# OpenAI Responses API. Required for real Nexus AI responses.
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: override the model used by /api/ai/* routes.
# Leave this unset to use the app default.
OPENAI_MODEL=gpt-5.6

# Optional Firebase web config. If omitted, Nexus GPT uses localStorage + BroadcastChannel for demos.
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
